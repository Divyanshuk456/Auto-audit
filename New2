Temperature

<input type="text" id="temperature">

<script>

$("#line").change(function(){

var line=$("#line").val();

$.ajax({

url:"autofill.php",

type:"POST",

data:{line:line},

dataType:"json",

success:function(data){

$("#pcb").val(data.top.pcb);

$("#pressure").val(data.top.pressure);

$("#temperature").val(data.top.temperature);

}

});

});

</script>

