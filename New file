Step 4 - autofill.php

    <?php

    include "machines.php";

    header("Content-Type: application/json");

    $line=$_GET['line'];

    if(!isset($machines[$line])){
    echo json_encode(["error"=>"Invalid Line"]);
    exit;
    }

    function latestFile($folder){

    $files=glob($folder."\\*.txt");

    if(empty($files))
    return false;

    usort($files,function($a,$b){
    return filemtime($b)-filemtime($a);
    });

    return $files[0];
    }

    function readLog($folder){

    $file=latestFile($folder);

    if(!$file)
    return [];

    $data=[];

    $lines=file($file,FILE_IGNORE_NEW_LINES);

    foreach($lines as $line){

    if(strpos($line,":")!==false){

    list($key,$value)=explode(":",$line,2);

    $data[trim($key)]=trim($value);

    }

    }

    return $data;

    }

    $top=readLog($machines[$line]["top"]);
    $bottom=readLog($machines[$line]["bottom"]);

    echo json_encode([

    "top"=>[
    "pcbThickness"=>$top["PCB Thickness"] ?? "",
    "pressure"=>$top["Pressure"] ?? "",
    "temperature"=>$top["Temperature"] ?? ""
    ],

    "bottom"=>[
    "pcbThickness"=>$bottom["PCB Thickness"] ?? "",
    "pressure"=>$bottom["Pressure"] ?? "",
    "temperature"=>$bottom["Temperature"] ?? ""
    ]

    ]);

    ?>

